    {
      "name": "Devices",
      "item": [
        {
          "name": "Create Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    if (!pm.collectionVariables.get('device_id')) {",
                  "        pm.collectionVariables.set('device_id', jsonData._id);",
                  "        console.log('Device ID saved:', jsonData._id);",
                  "    } else if (!pm.collectionVariables.get('device2_id')) {",
                  "        pm.collectionVariables.set('device2_id', jsonData._id);",
                  "        console.log('Device 2 ID saved:', jsonData._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Device 1\",\n  \"serial_number\": \"DEVICE001\",\n  \"model\": \"Test Model\",\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/devices",
              "host": ["{{base_url}}"],
              "path": ["devices"]
            }
