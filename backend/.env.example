# ─── คัดลอกเป็น .env แล้วแก้ค่า — อย่าคอมมิตไฟล์ .env ───

NODE_ENV=development
PORT=3031

# MongoDB
MONGO_URI=mongodb://localhost:27017/boxphone

# JWT (production: ใช้ค่าสุ่มยาว อย่างน้อย 32 ตัวอักษร)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=1d

# Socket auth for device/agent clients (required for device websocket connections)
DEVICE_SOCKET_SECRET=change-me-device-socket-secret-32chars

# bcrypt (optional)
BCRYPT_SALT_ROUNDS=10

# ─── Deploy หลัง Nginx / HTTPS ───
# ตั้งเป็น true เมื่อรันอยู่หลัง reverse proxy (rate limit / IP จาก X-Forwarded-For)
TRUST_PROXY=true

# คั่นด้วย comma — production บังคับต้องมี (REST + Socket.IO ใช้ชุดเดียวกัน)
# ตัวอย่าง:
# CORS_ORIGINS=https://user.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ถ้า admin + user อยู่คนละ subdomain แต่ใช้คุกกี้ร่วมกับ API บนโดเมนหลัก (optional)
# COOKIE_DOMAIN=.example.com

# ─── Admin seed (ตอนสตาร์ทแอป) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# production default: false (prevent resetting admin password on every restart)
ALLOW_ADMIN_SEED_IN_PRODUCTION=false

# ─── Xiaowei (ถ้าใช้) ───
XIAOWEI_WS_URL=ws://127.0.0.1:22222/
XIAOWEI_API_URL=http://127.0.0.1:8080
# XIAOWEI_API_KEY=
# XIAOWEI_USERNAME=
# XIAOWEI_PASSWORD=

# ─── ADB / Screenshot (เครื่องที่ต่อ USB — มักไม่ใช่บน Hetzner) ───
# ADB_PATH=adb
# SCREENSHOT_CACHE_TTL_MS=8000
# SCREENSHOT_MAX_CONCURRENT=2

# ─── Session (optional) ───
# SESSION_MAX_MOVE_COUNT=
# SESSION_DEFAULT_DISCONNECT_REASON=

# ─── Activity logs → Google Sheets (archive + monthly cleanup) ───
# สร้าง Service Account ใน Google Cloud, เปิด Google Sheets API, แชร์สเปรดชีตกับ client_email
# GOOGLE_SHEETS_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_SHEETS_TAB_NAME=Sheet1
# ใส่ JSON ทั้งก้อน (private_key ใช้ \\n คั่นบรรทัด) หรือชี้ไฟล์แทน:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
