# ─── คัดลอกเป็น .env แล้วแก้ค่า — อย่าคอมมิตไฟล์ .env ───

NODE_ENV=development
PORT=3031

# MongoDB
MONGO_URI=mongodb://localhost:27017/boxphone

# JWT (production: ใช้ค่าสุ่มยาว อย่างน้อย 32 ตัวอักษร)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=1d

# Socket auth for device/agent clients (required for device websocket connections)
DEVICE_SOCKET_SECRET=change-me-device-socket-secret-32chars

# bcrypt (optional)
BCRYPT_SALT_ROUNDS=10

# ─── Deploy หลัง Nginx / HTTPS ───
# ตั้งเป็น true เมื่อรันอยู่หลัง reverse proxy (rate limit / IP จาก X-Forwarded-For)
TRUST_PROXY=true

# คั่นด้วย comma — production บังคับต้องมี (REST + Socket.IO ใช้ชุดเดียวกัน)
# ตัวอย่าง:
# CORS_ORIGINS=https://user.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cross-subdomain cookie sharing. REQUIRED ถ้า admin/user/api อยู่คนละ subdomain
# เช่น admin.example.com / user.example.com / api.example.com → COOKIE_DOMAIN=.example.com
# ถ้าไม่ตั้ง: cookie จะอยู่เฉพาะ host ที่ตอบ Set-Cookie (logout จะ clear ไม่ครบ)
COOKIE_DOMAIN=.example.com

# ─── Admin seed (ตอนสตาร์ทแอป) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# production default: false (prevent resetting admin password on every restart)
ALLOW_ADMIN_SEED_IN_PRODUCTION=false

# ─── Xiaowei (ถ้าใช้) ───
XIAOWEI_WS_URL=ws://127.0.0.1:22222/
XIAOWEI_API_URL=http://127.0.0.1:8080
# XIAOWEI_API_KEY=
# XIAOWEI_USERNAME=
# XIAOWEI_PASSWORD=

# ─── ADB / Screenshot (เครื่องที่ต่อ USB — มักไม่ใช่บน Hetzner) ───
# ADB_PATH=adb
# ADB_TOUCH_MODE=swipe
# swipe = best for Samsung Galaxy Note (short swipe segments)
# motionevent = optional; auto-fallback to swipe on failure
# SCREENSHOT_CACHE_TTL_MS=8000
# SCREENSHOT_MAX_CONCURRENT=2

# ─── Streaming Mode (Feature Flag) ───────────────────────────────────
# 'screenshot' = legacy polling (PNG every 2s) — ค่า default ปลอดภัย
# 'scrcpy'     = H.264 video streaming (30 FPS real-time) — ต้องมี adb + scrcpy-server.jar
STREAMING_MODE=screenshot

# ─── scrcpy H.264 Streaming (เปิดเมื่อ STREAMING_MODE=scrcpy) ──────────
# scrcpy-server.jar version ที่ใช้ — ต้องตรงกับไฟล์ใน backend/assets/
SCRCPY_SERVER_VERSION=2.4
# Video bitrate (bps) — 3 Mbps = quality ดี + bandwidth ปานกลาง
SCRCPY_VIDEO_BITRATE=3000000
# Max FPS — 30 พอสำหรับ UI ทั่วไป, 60 สำหรับเกม (ใช้ bandwidth เพิ่มเท่าตัว)
SCRCPY_MAX_FPS=30
# Resize ฝั่ง Android ก่อน encode (ด้านที่ยาวที่สุด, px) — 1280 = balance ดีสุด
SCRCPY_MAX_SIZE=1280
# TCP port pool (host side) — adb forward จะใช้ port ในช่วงนี้
SCRCPY_PORT_POOL_START=27183
SCRCPY_PORT_POOL_SIZE=100
# ปิด scrcpy หลังไม่มี subscriber กี่ ms (ป้องกันเปิดปิดถี่)
SCRCPY_IDLE_TIMEOUT_MS=30000
# จำนวน stream ที่รันพร้อมกันสูงสุด (กัน CPU/RAM ตาย)
MAX_CONCURRENT_STREAMS=20

# ─── Session (optional) ───
# SESSION_MAX_MOVE_COUNT=
# SESSION_DEFAULT_DISCONNECT_REASON=

# ─── Activity logs → Google Sheets (archive + monthly cleanup) ───
# สร้าง Service Account ใน Google Cloud, เปิด Google Sheets API, แชร์สเปรดชีตกับ client_email
# GOOGLE_SHEETS_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_SHEETS_TAB_NAME=Sheet1
# ใส่ JSON ทั้งก้อน (private_key ใช้ \\n คั่นบรรทัด) หรือชี้ไฟล์แทน:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
