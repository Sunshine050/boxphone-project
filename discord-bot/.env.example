# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Secret token shared with the NestJS backend — must match X-Webhook-Secret header
WEBHOOK_SECRET=your_webhook_secret_here

# Port for the webhook HTTP server
PORT=4000

# Discord User ID ของ admin สำหรับรับ DM แจ้งเตือนทุก event
ADMIN_DISCORD_ID=your_admin_discord_user_id_here

# Deduplication window in milliseconds (default: 60000 = 1 minute)
DEDUP_WINDOW_MS=60000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
